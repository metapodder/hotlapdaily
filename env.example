# ─────────────────────────────────────────────────────────────────────────────
# Hotlap Daily — environment configuration
#
# Everything here is OPTIONAL. With no .env at all, the app runs out of the box
# using an in-memory database (see DB_BACKEND below). Copy this file to `.env`
# only when you want to change the defaults.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database backend --------------------------------------------------------
# "memory"   -> in-memory store, zero setup (default when DATABASE_URL is unset).
#               Data optionally persists to ./.data/hotlap-db.json between runs.
# "postgres" -> Prisma + PostgreSQL (default when DATABASE_URL is set).
# DB_BACKEND=memory

# Disable on-disk persistence for the in-memory backend (data resets each run).
# DB_PERSIST=false

# PostgreSQL connection string. Setting this switches the backend to Postgres
# unless DB_BACKEND=memory is forced. Run `npm run db:push` to create the schema.
# DATABASE_URL="postgresql://username:password@localhost:5432/hotlapdaily?schema=public"
#   PostgreSQL: postgresql://username:password@localhost:5432/database_name
#   Supabase:   postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
#   Neon:       postgresql://username:password@ep-xxx.aws.neon.tech/neondb

# --- Admin dashboard ---------------------------------------------------------
# Password for /dashboard (track review/management). If unset, the dashboard
# auth endpoint returns "Server misconfigured".
# PASSWORD_ADMIN=change-me

# --- Anti-cheat --------------------------------------------------------------
# Secret used to sign proof-of-work challenges for lap submission. If unset, an
# ephemeral per-process secret is generated (fine for local dev; set a stable
# value in production so challenges survive restarts / multiple instances).
# HOTLAPDAILY_CHALLENGE_SECRET=some-long-random-string

# --- Misc --------------------------------------------------------------------
# SHOW_DISCORD_INVITE=true
